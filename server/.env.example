# Server Configuration
PORT=3001
NODE_ENV=development

# OIDC / OAuth 2.0 Configuration
# Example using Auth0, Okta, or any OIDC provider
OIDC_ISSUER=https://YOUR_DOMAIN.auth0.com
OIDC_CLIENT_ID=your_client_id
OIDC_CLIENT_SECRET=your_client_secret
OIDC_REDIRECT_URI=http://localhost:3001/auth/callback
OIDC_SCOPES=openid profile email

DEMO_MODE=true

# JWT Configuration
JWT_SECRET=your_jwt_secret_min_32_chars_long_change_this
JWT_EXPIRY=8h

# Session
SESSION_SECRET=your_session_secret_change_this

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=livetrack-server
KAFKA_TOPIC_LOCATION=location-updates
KAFKA_CONSUMER_GROUP_SOCKET=socket-broadcaster
KAFKA_CONSUMER_GROUP_DB=db-persister

# SQLite Database (for location history simulation)
DB_PATH=./livetrack.db


# Local dev
VITE_SERVER_URL=http://localhost:3001
# Docker (if using nginx proxy, leave empty or use relative URL)
# VITE_SERVER_URL=